# ─────────────────────────────────────────────
# Discord Bot
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id

# ─────────────────────────────────────────────
# Riot / HenrikDev API
# ─────────────────────────────────────────────
# HenrikDev API key — free from https://discord.gg/clans
# Required for production rate limits (50k+ members).
# Leave blank to run unauthenticated (30 req/min, dev only).
HENRIK_API_KEY=

# Official Riot Games API key — apply at https://developer.riotgames.com
# Once you have a production key, paste it here.
# The bot uses HenrikDev as the primary source; the official key is a fallback.
RIOT_API_KEY=

# ─────────────────────────────────────────────
# Bot config
# ─────────────────────────────────────────────
# Default Valorant region shown when none is provided (na | eu | ap | latam | br | kr)
DEFAULT_REGION=ap

# How long (minutes) a pending /verify confirm can wait before expiring
VERIFICATION_TIMEOUT_MINUTES=10

# Role IDs that count as "admin" for the bot's admin commands (comma-separated).
# If left blank, only users with Administrator permission can use admin commands.
# Example: ADMIN_ROLE_IDS=111222333444555666,777888999000111222
ADMIN_ROLE_IDS=

# Optional: guild ID to register slash commands to during development (instant).
# Leave blank to register commands globally (up to 1 hour to propagate).
DEV_GUILD_ID=
