# ─────────────────────────────────────────────
# Discord Bot
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id

# ─────────────────────────────────────────────
# Riot / HenrikDev API
# ─────────────────────────────────────────────
# HenrikDev API key — free from https://discord.gg/clans
# Required for production rate limits (50k+ members).
# Leave blank to run unauthenticated (30 req/min, dev only).
HENRIK_API_KEY=

# Official Riot Games API key — apply at https://developer.riotgames.com
# Once you have a production key, paste it here.
# The bot uses HenrikDev as the primary source; the official key is a fallback.
RIOT_API_KEY=

# ─────────────────────────────────────────────
# Bot config
# ─────────────────────────────────────────────
# Default Valorant region shown when none is provided (na | eu | ap | latam | br | kr)
DEFAULT_REGION=ap

# How long (minutes) a pending /verify confirm can wait before expiring
VERIFICATION_TIMEOUT_MINUTES=10

# Encryption-at-rest key for the SQLite database (required in production).
# When set, the bot.db file is AES-encrypted via better-sqlite3-multiple-ciphers.
# Use a long random string. NOTE: changing or losing this key makes the
# existing database unreadable — back it up. An existing UNENCRYPTED bot.db
# cannot be opened with a key set; start with a fresh DB when enabling this.
DB_ENCRYPTION_KEY=

# Restricted role — these members can ONLY run /lock and /unlock (no linking, no other commands)
RESTRICTED_ROLE_ID=

# ─────────────────────────────────────────────
# Staff permission hierarchy (cumulative — each tier inherits all lower tiers' commands)
#   Moderator        → /lookup, /links
#   Senior Moderator → + /resetlink
#   Admin            → + /serverstats, /exportlinks
#   Senior Admin     → + /setlink, /bulkreset, /linkpanel, /logsetup
#   Head Admin       → (everything prior)
#   Senior Management→ (everything prior)
# Discord Administrator permission and BYPASS_USER_IDS always count as max level.
STAFF_ROLE_MOD=
STAFF_ROLE_SNR_MOD=
STAFF_ROLE_ADMIN=
STAFF_ROLE_SNR_ADMIN=
STAFF_ROLE_HEAD_ADMIN=
STAFF_ROLE_SNR_MGMT=

# Users who can run every command irrespective of roles (comma-separated)
BYPASS_USER_IDS=

# Legacy single-tier admin roles (comma-separated). Superseded by STAFF_ROLE_* above;
# kept for backward compatibility. Leave blank if using the hierarchy.
ADMIN_ROLE_IDS=

# Optional: guild ID to register slash commands to during development (instant).
# Leave blank to register commands globally (up to 1 hour to propagate).
DEV_GUILD_ID=

# Main server (guild) ID — required for --main-guild / --main-full deploys.
MAIN_GUILD_ID=
